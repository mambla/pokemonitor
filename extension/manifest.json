{
  "manifest_version": 3,
  "name": "PokeMonitor",
  "version": "3.0.0",
  "description": "Monitor Facebook groups and get AI-powered alerts via browser notifications and Telegram",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "tabGroups",
    "notifications"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.telegram.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.facebook.com/groups/*"],
      "js": ["parser.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
